# Copy this file to .env and fill in your values

# ── LLM Providers ────────────────────────────────────────────
# Primary: Google Gemini (https://aistudio.google.com/)
GOOGLE_API_KEY=your_gemini_api_key_here

# Fallback: Groq (https://console.groq.com/) — auto-used when Gemini hits rate limits
GROQ_API_KEY=your_groq_api_key_here

# ── Model Settings ────────────────────────────────────────────
# Gemini model — gemini-3.1-flash-lite-preview gives 500 RPD / 15 RPM on free tier
DEFAULT_LLM=gemini-3.1-flash-lite-preview

# Groq fallback model — llama-3.3-70b-versatile gives 1000 RPD on free tier
GROQ_MODEL=llama-3.3-70b-versatile

EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Database ───────────────────────────────────────────
VECTOR_DB_PATH=./vector_db
COLLECTION_NAME=gita_wisdom

# ── App Settings ──────────────────────────────────────────────
MAX_CONTEXT_LENGTH=3500
MAX_RESULTS=10
